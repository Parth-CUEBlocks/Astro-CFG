---
// src/pages/index.astro
import HomepageHero from '../components/homepage/HomepageHero.astro';
import Testimonials from '../components/homepage/Testimonials.astro';
// Import our custom front page Less compilation
import Layout from '../layouts/Layout.astro';
import '../styles/homepage.less';
import blog1 from '../assets/blog1.png';
import Whoweare from '../components/homepage/Whoweare.astro';
import Homecasestudy from '../components/homepage/Homecasestudy.astro';

---

<Layout title="CueForGood | eCommerce Agency for B Corps, Sustainable & Purpose Driven Brands">
  
  <HomepageHero/>
  <Whoweare/>
  <Homecasestudy/>
  <Testimonials />

  <section class="cfg-blog-viewport">
    <div class="cfg-blog-container">
      <h2 class="cfg-blog-heading">Latest Posts</h2>
      
      <div class="cfg-blog-grid">
        <article class="cfg-blog-card">
          <div class="cfg-blog-image-wrapper">
            <img src={blog1.src} alt="Fastest Shopify Themes 2025" />
          </div>
          <h3 class="cfg-blog-title">Fastest Shopify Themes 2025 – Tested & Ranked using Google PageSpeed Insights</h3>
          <p class="cfg-blog-excerpt">Beautiful and feature-rich themes can directly impact user-journeys and conversions.</p>
          <a href="/blog/fastest-shopify-themes-2025" class="cfg-blog-btn">Read Full Post</a>
        </article>

        <article class="cfg-blog-card">
          <div class="cfg-blog-image-wrapper">
            <img src={blog1.src} alt="Optimize & Track Google Discover" />
          </div>
          <h3 class="cfg-blog-title">How to Optimize & Track Google Discover in Google Analytics</h3>
          <p class="cfg-blog-excerpt">Google Discover is a curated content feed inside the Google app. The app has more than 800 million monthly active users in Android and iOS phones.</p>
          <a href="/blog/optimize-track-google-discover" class="cfg-blog-btn">Read Full Post</a>
        </article>

        <article class="cfg-blog-card">
          <div class="cfg-blog-image-wrapper">
            <img src={blog1.src} alt="Sustainable Marketing Principles" />
          </div>
          <h3 class="cfg-blog-title">Discover Essential Sustainable Marketing Principles and Strategies for Ethical Business Growth</h3>
          <p class="cfg-blog-excerpt">Given the major issues that our world is currently facing, such as pollution and climate change, sustainability...</p>
          <a href="/blog/sustainable-marketing-principles" class="cfg-blog-btn">Read Full Post</a>
        </article>
      </div>
    </div>
  </section>

  <!-- <section class="cfg-bottom-cta">
    <div class="cfg-cta-inner">
      <h2 class="cfg-cta-title">Let’s make a difference together.</h2>
      <p class="cfg-cta-desc">Ready to grow your mission-driven brand with a scalable digital ecosystem?</p>
      <a href="/contact" class="cfg-cta-button">Get in Touch</a>
    </div>
  </section> -->

</Layout>