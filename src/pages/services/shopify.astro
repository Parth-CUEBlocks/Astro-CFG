---
import Layout from '../../layouts/Layout.astro';
import '../../styles/shopify.less';
---

<Layout title="Shopify Agency for B Corps & Purpose-Driven Brands | CueForGood">
  <div class="cfg-shopify-outer-wrapper">
    <div class="cfg-shopify-inner-container">

      <section class="cfg-shopify-hero">
        <div class="cfg-hero-grid">
          <div class="cfg-hero-content">
            <div class="cfg-badge-circle">
              <span>OVER 10 YEARS<br />OF EXCELLENCE</span>
            </div>
            <h1 class="cfg-hero-title">Shopify Solutions For B Corps & Purpose-Driven Brands</h1>
            <p class="cfg-hero-desc">
              Custom e-commerce for impact-driven brands. We build sustainable, high-converting Shopify stores that scale your mission and business. Empowering sustainable brands with modern design, optimal code performance, and seamless user experiences.
            </p>
          </div>

          <div class="cfg-hero-media">
            <div class="cfg-hero-card">
              <div class="cfg-badge-grid">
                <div class="cfg-badge-icon">
                  <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 12h5a2.5 2.5 0 0 0 0-5H8v10h5.5a2.5 2.5 0 0 0 0-5H8"/></svg>
                </div>
                <div class="cfg-badge-icon">
                  <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 3v18M3 12h18"/></svg>
                </div>
                <div class="cfg-badge-icon cfg-shopify-badge">
                  <svg width="60" height="60" viewBox="0 0 24 24" fill="#95bf47"><path d="M18.5 6.5L14.8 2.8c-.3-.3-.8-.5-1.3-.5H10.5c-.5 0-1 .2-1.3.5L5.5 6.5c-.4.4-.5 1-.4 1.5l2.2 11.2c.1.7.7 1.3 1.5 1.3h6.4c.8 0 1.4-.6 1.5-1.3l2.2-11.2c.1-.5 0-1.1-.4-1.5z"/></svg>
                </div>
                <div class="cfg-badge-icon">
                  <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5"><text x="5" y="16" font-size="12" fill="#fff" font-weight="bold">1%</text></svg>
                </div>
                <div class="cfg-badge-icon">
                  <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"/></svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="cfg-approach-section">
        <h2 class="cfg-section-heading">OUR APPROACH</h2>
        <div class="cfg-approach-grid">
          
          <div class="cfg-approach-card">
            <div class="cfg-approach-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#8b95a5" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M1 12h4M19 12h4"/></svg>
            </div>
            <h3>Defined Approach</h3>
            <p>A structured workflow with clear milestones and continuous feedback loops ensures your project stays on schedule and budget.</p>
          </div>

          <div class="cfg-approach-card">
            <div class="cfg-approach-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#8b95a5" stroke-width="1.5"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M12 16v4M8 20h8M9 9l2 2 4-4"/></svg>
            </div>
            <h3>Best Practice Adherence</h3>
            <p>Ensuring clean code quality, fast loading speeds, and security compliance to deliver a scalable e-commerce store.</p>
          </div>

          <div class="cfg-approach-card">
            <div class="cfg-approach-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#8b95a5" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><polygon points="12 8 10 14 16 12 14 10 12 8"/></svg>
            </div>
            <h3>Consultative Approach</h3>
            <p>Strategic insights, ongoing advice, and e-commerce consulting to help you make informed decisions for long-term growth.</p>
          </div>

        </div>
      </section>

      <section class="cfg-services-section">
        <h2 class="cfg-services-title">Our Shopify Services</h2>

        <div class="cfg-service-row">
          <div class="cfg-service-img">
            <img src="https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?auto=format&fit=crop&w=800&q=80" alt="Custom Shopify Store Development" />
          </div>
          <div class="cfg-service-details">
            <h3>Custom Shopify Store Development</h3>
            <p>Building tailored e-commerce experiences from scratch aligned with your brand's purpose, optimizing user experience for modern mobile shoppers and high conversion rates.</p>
            <a href="#contact" class="cfg-service-btn">GET IN TOUCH</a>
          </div>
        </div>

        <div class="cfg-service-row cfg-row-reverse">
          <div class="cfg-service-img">
            <img src="https://images.unsplash.com/photo-1523381210434-271e8be1f52b?auto=format&fit=crop&w=800&q=80" alt="Migration To Shopify From Another Platform" />
          </div>
          <div class="cfg-service-details">
            <h3>Migration To Shopify From Another Platform</h3>
            <p>Easily transition from WooCommerce, Magento, BigCommerce, or custom platforms to Shopify without losing SEO rank, customer data, or transaction history.</p>
            <a href="#contact" class="cfg-service-btn">GET IN TOUCH</a>
          </div>
        </div>

        <div class="cfg-service-row">
          <div class="cfg-service-img">
            <img src="https://images.unsplash.com/photo-1556742049-0a67dd642646?auto=format&fit=crop&w=800&q=80" alt="Shopify Performance Audit & Optimization" />
          </div>
          <div class="cfg-service-details">
            <h3>Shopify Performance Audit & Optimization</h3>
            <p>Boost your page load speed, fix UX bottlenecks, and optimize core web vitals to elevate customer satisfaction and search engine visibility.</p>
            <a href="#contact" class="cfg-service-btn">GET IN TOUCH</a>
          </div>
        </div>

        <div class="cfg-service-row cfg-row-reverse cfg-highlight-box">
          <div class="cfg-service-img">
            <img src="https://images.unsplash.com/photo-1512428559087-560fa5ceab42?auto=format&fit=crop&w=800&q=80" alt="Shopify Apps Integration" />
          </div>
          <div class="cfg-service-details">
            <h3>Shopify Apps Integration</h3>
            <p>Extend your store functionality with seamless third-party app integrations for subscriptions, loyalty programs, carbon offsets, and ERP systems.</p>
            <a href="#contact" class="cfg-service-btn cfg-btn-dark">GET IN TOUCH</a>
          </div>
        </div>

        <div class="cfg-service-row">
          <div class="cfg-service-img">
            <img src="https://images.unsplash.com/photo-1502680390469-be75c86b636f?auto=format&fit=crop&w=800&q=80" alt="Shopify Theme Integration" />
          </div>
          <div class="cfg-service-details">
            <h3>Shopify Theme Integration</h3>
            <p>We configure and customize premium standard themes to align with your brand visual identity, ensuring fast time-to-market and robust mobile responsiveness.</p>
            <a href="#contact" class="cfg-service-btn">GET IN TOUCH</a>
          </div>
        </div>

        <div class="cfg-service-row cfg-row-reverse">
          <div class="cfg-service-img">
            <img src="https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?auto=format&fit=crop&w=800&q=80" alt="Shopify Plus Development" />
          </div>
          <div class="cfg-service-details">
            <h3>Shopify Plus Development</h3>
            <p>Enterprise solutions for high-growth B Corp brands requiring custom checkout extensions, multi-currency support, and complex API workflow automation.</p>
            <a href="#contact" class="cfg-service-btn">GET IN TOUCH</a>
          </div>
        </div>

        <div class="cfg-service-row">
          <div class="cfg-service-img">
            <img src="https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&w=800&q=80" alt="Custom Features & Development" />
          </div>
          <div class="cfg-service-details">
            <h3>Custom Features & Development</h3>
            <p>Custom dynamic features, impact calculators, bespoke product builders, and tailored front-end integrations built specifically for your brand's mission.</p>
            <a href="#contact" class="cfg-service-btn">GET IN TOUCH</a>
          </div>
        </div>

      </section>

      <section class="cfg-cta-banner" id="contact">
        <div class="cfg-cta-flex">
          <div class="cfg-cta-text">
            <h2>Ready to Scale Your Mission?</h2>
            <p>Let's talk about it!</p>
          </div>
          <div class="cfg-cta-action">
            <a href="mailto:hello@cueforgood.com" class="cfg-cta-btn">Contact us</a>
          </div>
        </div>
      </section>

    </div>
  </div>
</Layout>