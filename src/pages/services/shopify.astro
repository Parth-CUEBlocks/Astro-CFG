---
import Layout from '../../layouts/Layout.astro';
import '../../styles/shopify.less';
import CustomShopifyStoreDevelopment from '../../assets/page.shopify/CustomShopifyStoreDevelopment.png';
import s_1_b from '../../assets/page.shopify/s_1_b.png';
import s_2 from '../../assets/page.shopify/s_2.png';
import s_3 from '../../assets/page.shopify/s_3.png';
import shopifylogo from '../../assets/page.shopify/shopify-logo.png';
import shopify_hero from '../../assets/page.shopify/shopify_hero_b.png';
import DiamondDesigns from '../../assets/page.shopify/DiamondDesigns.png';
import retro_mobile from '../../assets/page.shopify/retro_mobile.png';
---

<Layout title="Shopify Agency for B Corps & Purpose-Driven Brands | CueForGood">
  <div class="cfg-shopify-outer-wrapper">
    <div class="cfg-shopify-inner-container">

      <!-- HERO SECTION -->
      <section class="cfg-shopify-hero">
        <div class="cfg-hero-grid">
          
          <!-- Left Column -->
          <div class="cfg-hero-content">
            <div class="flex-hero"><h1 class="cfg-hero-title">Shopify Solutions For B Corps & Purpose-Driven Brands</h1><img src={shopifylogo.src} alt="shopify logo"/></div>
            <h2 class="cfg-hero-subtitle">Sustainable E-Commerce for Impact-Driven Growth</h2>
            
            <p class="cfg-hero-desc">
              Customers today are not just buying products, they're supporting missions. At CueForGood, we help B Corps and purpose-driven brands translate their values into intuitive, scalable Shopify experiences. Whether you're building from scratch or enhancing an existing store, we create seamless e-commerce environments that support growth, impact, and sustainability.
            </p>
          </div>

          <!-- Right Column (Single Image) -->
          <div class="cfg-hero-media">
            <img src={shopify_hero.src} alt="Shopify Expert & Certifications Graphic" class="cfg-hero-total-img" />
          </div>

        </div>
      </section>

      <!-- OUR APPROACH SECTION -->
      <section class="cfg-approach-section">
        <h2 class="cfg-section-heading">OUR APPROACH</h2>
        
        <div class="cfg-approach-grid">
          
          <div class="cfg-approach-card">
            <div class="cfg-approach-icon">
              <img src={s_1_b.src} alt="Defined Approach Icon" />
            </div>
            <h3>Defined Approach</h3>
            <p>Our certified Shopify developers follow a structured, transparent process to ensure efficient collaboration, on-time delivery, and technical precision.</p>
          </div>

          <div class="cfg-approach-card">
            <div class="cfg-approach-icon">
              <img src={s_2.src} alt="Best Practice Adherence Icon" />
            </div>
            <h3>Best Practice Adherence</h3>
            <p>We follow both web development and Shopify standards to build fast, secure, and compliant storefronts, delivering reliable, scalable solutions from day one.</p>
          </div>

          <div class="cfg-approach-card">
            <div class="cfg-approach-icon">
              <img src={s_3.src} alt="Consultative Approach Icon" />
            </div>
            <h3>Consultative Approach</h3>
            <p>With deep experience in purpose-led e-commerce, we advise clients on design, tools, and trends that align with their business goals and mission. No cookie-cutter answers, just tailored guidance with real impact.</p>
          </div>

        </div>
      </section>

      <!-- OUR SHOPIFY SERVICES SECTION -->
      <section class="cfg-services-section">
        <h2 class="cfg-services-title">Our Shopify Services</h2>

        <!-- Service 1 -->
        <div class="cfg-service-row">
          <div class="cfg-service-img">
            <img src={CustomShopifyStoreDevelopment.src} alt="Custom Shopify Store Development" />
          </div>
          <div class="cfg-service-details">
            <h3>Custom Shopify Store Development</h3>
            <p>We design and build fully custom Shopify stores that represent your brand's values and deliver a frictionless experience to your users, whether you're a B Corp, a mission-driven startup, or a growing ethical brand.</p>
            <p class="cfg-service-callout">Write to us to see how Shopify can serve your vision.</p>
            <a href="#contact" class="cfg-service-btn">GET IN TOUCH</a>
          </div>
        </div>

        <!-- Service 2 -->
        <div class="cfg-service-row cfg-row-reverse">
          <div class="cfg-service-img">
            <img src={DiamondDesigns.src} alt="Migration To Shopify From Another Platform" />
          </div>
          <div class="cfg-service-details">
            <h3>Migration To Shopify From Another Platform</h3>
            <p>Ready to switch to a scalable, user-friendly platform? Whether you're moving from WooCommerce, Magento, or any self-hosted setup, we ensure a smooth transition to Shopify with minimal downtime, while preserving your store's integrity and functionality.</p>
            <p class="cfg-service-callout">Let's talk about making your migration seamless.</p>
            <a href="#contact" class="cfg-service-btn">GET IN TOUCH</a>
          </div>
        </div>

        <!-- Service 3 (Shopify Apps Integration Banner) -->
        <div class="cfg-service-row cfg-highlight-box">
          <div class="cfg-service-details">
            <h3>Shopify Apps Integration</h3>
            <p>From carbon offset tools to loyalty programs and donation plugins, we help you choose and integrate the apps that support both your business goals and your impact initiatives. Every integration is done with user experience and backend ease in mind.</p>
            <p class="cfg-service-callout">Need help choosing the right apps? Get in touch.</p>
            <a href="#contact" class="cfg-service-btn cfg-btn-dark">GET IN TOUCH</a>
          </div>
          <div class="cfg-service-img cfg-mobile-mockups">
            <img src={retro_mobile.src} alt="Shopify Apps Mobile Showcase" />
          </div>
        </div>

      </section>

      <section class="cfg-wp-purpose-section">
        <div class="cfg-wp-purpose-container">
          <h2 class="cfg-wp-purpose-title">Why WordPress For Purpose-Led Organizations</h2>
          
          <p class="cfg-wp-purpose-intro">
            As the leading open-source CMS, WordPress empowers mission-driven teams to build sustainable, user-friendly websites with complete control and long-term flexibility. It's the ideal platform for:
          </p>

          <ul class="cfg-wp-purpose-list">
            <li class="cfg-wp-purpose-item">
              <strong>Scalable WordPress solutions</strong> - Flexible enough to grow with your team, content, or cause
            </li>
            <li class="cfg-wp-purpose-item">
              <strong>Cost-effective development</strong> - Built on open-source technology with no licensing fees
            </li>
            <li class="cfg-wp-purpose-item">
              <strong>User-friendly nonprofit websites</strong> - Easy for internal teams to manage and update
            </li>
            <li class="cfg-wp-purpose-item">
              <strong>Accessible WordPress websites</strong> - Designed with WCAG and Section 508 compliance in mind
            </li>
            <li class="cfg-wp-purpose-item">
              <strong>Sustainable web development</strong> - Lean code and optimized hosting help reduce digital energy use
            </li>
          </ul>

          <p class="cfg-wp-purpose-outro">
            Whether you're sharing your story, raising donations, or managing member engagement, WordPress offers the right mix of flexibility, performance, and purpose-driven functionality.
          </p>
        </div>
      </section>

      <section class="cfg-feature-cards-section">
        <div class="cfg-shopify-inner-container">
          <div class="cfg-feature-cards-grid">
            <div class="cfg-feature-card">
              <h3 class="cfg-feature-card-title">WordPress SEO For Nonprofits</h3>
              <p class="cfg-feature-card-desc">
                We align your SEO strategy with your mission. From schema markup for events to keyword strategies around impact and community work-we help more of the right people find your site.
              </p>
            </div>
            <div class="cfg-feature-card">
              <h3 class="cfg-feature-card-title">Accessible WordPress Design</h3>
              <p class="cfg-feature-card-desc">
                Accessibility isn’t a checklist, it’s core to your digital presence. We build with keyboard users, screen readers, and neurodiverse visitors in mind, applying WCAG 2.1 and inclusive UX practices throughout.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- WHY ACCESSIBILITY MATTERS SECTION -->
      <section class="cfg-accessibility-section">
        <div class="cfg-accessibility-grid">
          
          <div class="cfg-accessibility-content">
            <h2 class="cfg-accessibility-title">Why Accessibility Matters for Purpose-Driven Brands</h2>
            <p class="cfg-accessibility-intro">
              An accessible website is about more than checklists; it widens your impact and proves your commitment to equity.
            </p>

            <ul class="cfg-accessibility-list">
              <li class="cfg-accessibility-item">
                <span class="cfg-check-icon">✓</span>
                <div>
                  <strong>Advance your mission</strong>
                  <p>Inclusion is a core B Corp metric for community and governance.</p>
                </div>
              </li>
              <li class="cfg-accessibility-item">
                <span class="cfg-check-icon">✓</span>
                <div>
                  <strong>Build trust, and advocacy</strong>
                  <p>Barrier-free journeys convert better, and inspire word-of-mouth.</p>
                </div>
              </li>
              <li class="cfg-accessibility-item">
                <span class="cfg-check-icon">✓</span>
                <div>
                  <strong>Boost organic reach</strong>
                  <p>Search engines reward well-structured, accessible code.</p>
                </div>
              </li>
              <li class="cfg-accessibility-item">
                <span class="cfg-check-icon">✓</span>
                <div>
                  <strong>Reduce legal and reputational risk</strong>
                  <p>Compliance shields against ADA, EAA, and other global regulations.</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="cfg-accessibility-media">
            <div class="cfg-accessibility-img-wrapper">
              <img src={CustomShopifyStoreDevelopment.src} alt="Accessibility Audit Report Dashboard" class="cfg-accessibility-img" />
            </div>
            <blockquote class="cfg-accessibility-quote">
              “Design that makes people give a damn begins with accessibility.”
            </blockquote>
          </div>

        </div>
      </section>

      <!-- ADA & EAA REGULATIONS SECTION -->
      <section class="cfg-regulations-section">
        <h2 class="cfg-regulations-title">ADA & EAA: Regulations You Can't Ignore</h2>
        
        <div class="cfg-regulations-grid">
          
          <!-- Column 1: ADA -->
          <div class="cfg-regulation-card">
            <div class="cfg-regulation-img-wrapper">
              <img src={CustomShopifyStoreDevelopment.src} alt="ADA Title III Compliance Graphic" class="cfg-regulation-img" />
            </div>
            <h3 class="cfg-regulation-card-title">ADA - Americans with Disabilities Act Title III (USA)</h3>
            <ul class="cfg-regulation-list">
              <li>Applies to public-facing businesses (so-called "places of public accommodation"), including ecommerce sites, and nonprofit portals.</li>
              <li>Courts routinely cite WCAG 2.1 AA as the practical benchmark for compliance.</li>
              <li>Non-compliance can trigger lawsuits, settlement costs, and reputational damage.</li>
            </ul>
          </div>

          <!-- Column 2: EAA -->
          <div class="cfg-regulation-card">
            <div class="cfg-regulation-img-wrapper">
              <img src={CustomShopifyStoreDevelopment.src} alt="EAA 2025 Compliance Graphic" class="cfg-regulation-img" />
            </div>
            <h3 class="cfg-regulation-card-title">EAA – European Accessibility Act (w.e.f. June 2025)</h3>
            <ul class="cfg-regulation-list">
              <li>Requires digital goods and services offered in the EU – from e-commerce and ticketing to banking, and e-books – to meet accessibility standards comparable to WCAG 2.1 AA.</li>
              <li>Affects any organisation selling or operating within EU markets, regardless of where it is headquartered.</li>
              <li>Key date: 28 June 2025 for new products and services; existing websites must comply by 2028.</li>
              <li>Enforcement tools include market withdrawal, fines, and consumer complaints handled by EU member-state authorities.</li>
            </ul>
          </div>

        </div>
      </section>

      <!-- HOW OUR PROCESS WORKS SECTION -->
      <section class="cfg-process-section">
        <div class="cfg-process-grid">
          
          <div class="cfg-process-media">
            <img src={CustomShopifyStoreDevelopment.src} alt="Person working on laptop" class="cfg-process-img" />
          </div>

          <div class="cfg-process-content">
            <h2 class="cfg-process-title">How Our Process Works</h2>
            <p class="cfg-process-intro">
              Our process is transparent, collaborative, and rooted in user-first thinking. Here is how we work together:
            </p>

            <div class="cfg-process-steps-grid">
              
              <div class="cfg-process-step">
                <div class="cfg-step-header">
                  <span class="cfg-step-num">01</span>
                  <h3 class="cfg-step-title">Discovery Call</h3>
                </div>
                <p class="cfg-step-desc">
                  We begin by understanding your platform, content structure, audience, and accessibility goals.
                </p>
              </div>

              <div class="cfg-process-step">
                <div class="cfg-step-header">
                  <span class="cfg-step-num">02</span>
                  <h3 class="cfg-step-title">Audit</h3>
                </div>
                <p class="cfg-step-desc">
                  We run SortSite, Lighthouse, and VoiceOver, along with detailed manual testing to flag gaps.
                </p>
              </div>

              <div class="cfg-process-step">
                <div class="cfg-step-header">
                  <span class="cfg-step-num">03</span>
                  <h3 class="cfg-step-title">Reporting</h3>
                </div>
                <p class="cfg-step-desc">
                  You receive a prioritised report mapped to WCAG 2.1, ADA, and EAA success criteria.
                </p>
              </div>

              <div class="cfg-process-step">
                <div class="cfg-step-header">
                  <span class="cfg-step-num">04</span>
                  <h3 class="cfg-step-title">Support</h3>
                </div>
                <p class="cfg-step-desc">
                  We guide your team or work directly with your developers to fix issues.
                </p>
              </div>

              <div class="cfg-process-step">
                <div class="cfg-step-header">
                  <span class="cfg-step-num">05</span>
                  <h3 class="cfg-step-title">Re-Audit</h3>
                </div>
                <p class="cfg-step-desc">
                  We retest the site to verify improvements and certify compliance.
                </p>
              </div>

              <div class="cfg-process-step">
                <div class="cfg-step-header">
                  <span class="cfg-step-num">06</span>
                  <h3 class="cfg-step-title">Monitoring (Optional)</h3>
                </div>
                <p class="cfg-step-desc">
                  Quarterly scans and alerts keep accessibility intact as your site evolves.
                </p>
              </div>

            </div>
          </div>

        </div>
      </section>

    </div>
  </div>
</Layout>