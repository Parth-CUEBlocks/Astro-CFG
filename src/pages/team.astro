---

<Layout title="CueForGood Team | The Specialists Helping Businesses Become a Force for Good">
  <main class="team-page-container">
    
    <section class="team-hero">
      <div class="subtitle-badge">You are in Good Company</div>
      <h1>Meet the <span>CueForGood</span> team</h1>
      <p>
        Meet the CueForGood team that works on amplifying the success of our 'for purpose' clients.
      </p>
    </section>

    <section class="team-grid-section">
      <div class="team-cards-grid">
        {teamMembers.map((member) => (
          <div class="team-card-wrapper">
            <div class="avatar-container">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 140" class="dummy-avatar-svg">
                <circle cx="70" cy="70" r="70" fill="#141822"/>
                <circle cx="70" cy="54" r="22" fill="#2d3545"/>
                <path d="M34 110c0-15 16-24 36-24s36 9 36 24H34z" fill="#2d3545"/>
              </svg>
            </div>
            <div class="card-meta">
              <h3>{member.name}</h3>
              <p class="role-text">{member.role}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="join-team-banner">
      <div class="banner-content">
        <h2>Join our team</h2>
        <p>We are always looking for passionate people to join us. Check out our open positions.</p>
        <a href="/career" class="cta-primary-link">See Open Roles &rarr;</a>
      </div>
    </section>

  </main>
</Layout>