  { name: 'Aravindkumar B', role: 'Sr. Shopify Developer' },
  { name: 'Urmila', role: 'Sr. Shopify Developer' },
  { name: 'Jyoti', role: 'Sr. Web Developer' },
  { name: 'Sumit Sharma', role: 'Sr. Web Developer' },
  { name: 'Ravinder Singh', role: 'Sr. Front End Developer' },
  { name: 'Sahil Singh', role: 'Front End Developer' },
  { name: 'Parth Gautam', role: 'Front End Developer' },
  { name: 'Sahil', role: 'Web Developer' },
  { name: 'Shreya', role: 'Intern - Web Developer' },
  { name: 'Dheeraj Kumar', role: 'Sr. Linux Administrator' },
  { name: 'Yash Pal', role: 'Division Head, Digital Marketing (CSE)' },
  { name: 'Rajiv Singha', role: 'Division Head - Organic Search' },
  { name: 'Vivek Puri', role: 'Manager - Digital Advertising' },
  { name: 'Rajender Kumar', role: 'Sr. Digital Advertising Specialist' },
  { name: 'Harleen Kaur Sandhu', role: 'Organic Search Strategist' },
  { name: 'Mannu Dhiman', role: 'Organic Search Strategist' },
  { name: 'Kunal Mahajan', role: 'Digital Advertising Specialist' },
  { name: 'Vikas', role: 'Intern - Organic Search Marketing' },
  { name: 'Shivam Thakur', role: 'UI/ UX Designer' },
  { name: 'Gaurav Jafrain', role: 'Team Lead - Quality Analyst' },
  { name: 'Priyanka Pabbi', role: 'Quality Analyst' },
  { name: 'Harsha Chaudhary', role: 'Intern - QA' },
  { name: 'Ketaky Sharma', role: 'Division Head - People & Culture' },
  { name: 'Krittika', role: 'ESG Analyst' },
  { name: 'Deep Sharma', role: 'Sr. Accountant' },
