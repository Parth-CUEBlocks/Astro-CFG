---
// src/components/Testimonials.astro
import { client } from "../../../lib/contentful"; 

const response = await client.getEntries({
  content_type: "homepageTestimonials"
});

// 1. Get the fields from the first entry
const data = response.items;

// 2. Access the 'testmonials' reference field (using the API schema's spelling)
const testimonialsList = (data as any[]) || [];
// console.log(testimonialsList);
---

<section class="cfg-testimonial-viewport">
  <div class="cfg-testimonial-container">
    
    <div class="cfg-quote-icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="52" height="41" viewBox="0 0 52 41" fill="none"><path d="M4.6176 36.7338C1.61315 33.5351 0 29.9453 0 24.1262C0 13.8915 7.16377 4.71626 17.5866 0.181641L20.1899 4.21068C10.4636 9.48851 8.5626 16.334 7.8028 20.6508C9.36879 19.8386 11.4188 19.5529 13.4284 19.7398C18.6904 20.229 22.8376 24.561 22.8376 29.9453C22.8376 35.5987 18.2678 40.1816 12.6307 40.1816C9.50139 40.1816 6.50892 38.7471 4.6176 36.7338ZM33.7799 36.7338C30.7756 33.5351 29.1624 29.9453 29.1624 24.1262C29.1624 13.8915 36.3261 4.71626 46.749 0.181641L49.3524 4.21068C39.6258 9.48851 37.725 16.334 36.9651 20.6508C38.5311 19.8386 40.5812 19.5529 42.5908 19.7398C47.8528 20.229 52 24.561 52 29.9453C52 35.5987 47.4303 40.1816 41.7932 40.1816C38.6638 40.1816 35.6714 38.7471 33.7799 36.7338Z" fill="#292E3B"></path></svg>
    </div>
    
    <h2 class="cfg-testimonial-heading">Client Speak</h2>
    
    <div class="swiper">
      <div class="swiper-wrapper">
        {testimonialsList.map((item) => {
          // Extract data from individual reference items
          const description = item.fields?.description ;
          const clientName = item.fields?.clientName;
          const websiteLogo = item.fields?.websiteLogo.fields?.file?.url;
          const websiteLogoalt = item.fields?.websiteLogo.fields?.title;
          
          return (
            <div class="swiper-slide">
              <p class="cfg-testimonial-text">
                {description}
              </p>
              <p class="cfg-testimonial-author">
                {clientName}
              </p>
              <div class="cfg-testimonial-brand">
                <img src={`https:${websiteLogo}`} alt={websiteLogoalt} />
              </div>
            </div>
          );
        })}
      </div> 
      
      <div class="swiper-button-prev">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left slick-arrow slick-prev" aria-hidden="true" data-role="none" style="display:block" currentslide="0" slidecount="8" currentSlide="3"><path d="m15 18-6-6 6-6"></path></svg>
      </div>
      <div class="swiper-button-next">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right slick-arrow slick-next" aria-hidden="true" data-role="none" style="display:block" currentslide="0" slidecount="8" currentSlide="3"><path d="m9 18 6-6-6-6"></path></svg>
      </div>
      <div class="swiper-pagination"></div>
    </div>

  </div>
</section>

<script>
  import '../../scripts/swiper.js'; 
</script>