---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

import partner1 from '../assets/partner1.svg';
import partner2 from '../assets/partner2.png';
import partner3 from '../assets/partner3.svg';
import partner4 from '../assets/partner4.svg';
import partner5 from '../assets/partner5.svg';
---
<footer class="site-footer">
  <div class="footer-partners-section">
    <h3>Our Partners:</h3>
    
    <div class=" partners-swiper">
      <div class="swiper-wrapper elements-align-center">
        
        <div class="swiper-slide partner-logo shopify">
          <img src={partner5.src} alt="Shopify Partners" loading="lazy" width="217px" height="auto"/>
        </div>

        <div class="swiper-slide partner-logo google">
          <img src={partner1.src} alt="Google Partner" loading="lazy" width="99px" height="auto"/>
        </div>

        <div class="swiper-slide partner-logo wpengine">
          <img src={partner3.src} alt="Klaviyo" loading="lazy" width="71px" height="auto"/>
        </div>

        <div class="swiper-slide partner-logo green-hosting">
          <img src={partner2.src} alt="Green Hosting by CueForGood" loading="lazy" width="160px"/>
        </div>

        <div class="swiper-slide partner-logo userway">
          <img src={partner4.src} alt="UserWay Accessibility" loading="lazy" width="160px"/>
        </div>

        <div class="swiper-slide partner-logo shopify">
          <img src={partner5.src} alt="Shopify Partners" loading="lazy" width="217px" height="auto"/>
        </div>

        <div class="swiper-slide partner-logo google">
          <img src={partner1.src} alt="Google Partner" loading="lazy" width="99px" height="auto"/>
        </div>

        <div class="swiper-slide partner-logo wpengine">
          <img src={partner3.src} alt="Klaviyo" loading="lazy" width="71px" height="auto"/>
        </div>

        <div class="swiper-slide partner-logo green-hosting">
          <img src={partner2.src} alt="Green Hosting by CueForGood" loading="lazy" width="160px"/>
        </div>

        <div class="swiper-slide partner-logo userway">
          <img src={partner4.src} alt="UserWay Accessibility" loading="lazy" width="160px"/>
        </div>
        
      </div>
    </div>
  </div>

  <div class="footer-navigation-band">
    <nav class="footer-nav">
      <a href="/team">Team</a>
      <a href="/services">Services</a>
      <a href="/our-work">Our Work</a>
      <a href="/sitemap">Sitemap</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact Us</a>
    </nav>
  </div>
  
  <div class="footer-meta-band">
    <p class="copyright">
      &copy; Copyright {currentYear} CueForGood Solutions Pvt. Ltd. <a href="#" style="pointer-events: none; color:inherit; text-decoration: none; display:block;">All Rights Reserved.</a>
      <a href="/privacy-policy" class="privacy-link">Privacy Policy</a>
    </p>
    
    <div class="footer-socials">
      <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.8c4.56-.93 8-4.96 8-9.8z"/></svg>
      </a>
      <a href="https://x.com" target="_blank" rel="noopener noreferrer" aria-label="X (formerly Twitter)">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
      </a>
      <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
    </div>
  </div>
</footer>