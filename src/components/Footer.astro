---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-partners-section">
    <h3>Our Partners:</h3>
    <div class="partners-grid">
      <div class="partner-logo shopify">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 36" height="32" fill="none">
          <path d="M19.5 6.2c-.4-.5-1-.8-1.7-.8h-7c-.7 0-1.3.3-1.7.8L4.2 13c-.4.5-.5 1.2-.3 1.8l3.2 11.4c.3.9 1.1 1.4 2 1.4h11.8c.9 0 1.7-.6 2-1.4l3.2-11.4c.2-.6.1-1.3-.3-1.8L19.5 6.2z" fill="#95BF47"/>
          <path d="M14.8 11.5c0-.6-.4-1-1-1h-3.6c-.6 0-1 .4-1 1v4c0 .6.4 1 1 1h3.6c.6 0 1-.4 1-1v-4z" fill="#fff"/>
          <text x="36" y="23" font-family="system-ui, sans-serif" font-weight="800" font-size="15" fill="#fff" letter-spacing="-0.02em">shopify</text>
          <text x="96" y="23" font-family="system-ui, sans-serif" font-weight="400" font-size="12" fill="#999" letter-spacing="0.02em">partners</text>
        </svg>
      </div>

      <div class="partner-logo google">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 36" height="32">
          <path d="M14.2 17.5v-3.7h8.1c-.1-.8-.7-2.4-2.4-3.5-1.5-1-3.5-1.7-6.1-1.7-5.5 0-10 4.5-10 10s4.5 10 10 10c3.1 0 5.3-1.3 6.5-2.5l2.9 2.8c-2.4 2.2-5.5 3.6-9.4 3.6-7.7 0-14-6.3-14-14s6.3-14 14-14c4.1 0 7.7 1.4 10.5 4.1 2.9 2.8 3.7 6.7 3.7 10.1 0 1.1-.1 1.9-.2 2.7h-11.6z" fill="#fff"/>
          <text x="32" y="27" font-family="system-ui, sans-serif" font-weight="400" font-size="13" fill="#aaa" letter-spacing="0.05em">Partner</text>
        </svg>
      </div>

      <div class="partner-logo klaviyo">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 110 32" height="26">
          <rect width="14" height="6" rx="1" fill="#fff"/>
          <rect y="10" width="22" height="6" rx="1" fill="#fff"/>
          <rect y="20" width="16" height="6" rx="1" fill="#fff"/>
          <text x="32" y="23" font-family="system-ui, sans-serif" font-weight="800" font-size="20" fill="#fff" letter-spacing="-0.04em">klaviyo</text>
        </svg>
      </div>

      <div class="partner-logo green-hosting">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 150 36" height="32">
          <rect width="150" height="36" rx="4" fill="#1e2530" stroke="#444" stroke-width="1"/>
          <text x="12" y="15" font-family="system-ui, sans-serif" font-weight="700" font-size="9" fill="#aaa" letter-spacing="0.05em">GREEN HOSTING</text>
          <text x="12" y="28" font-family="system-ui, sans-serif" font-weight="500" font-size="10" fill="#fff">cueforgood.com</text>
          <path d="M132 12c-4 0-6 3-6 6s2 6 6 6 6-3 6-6-2-6-6-6zm0 9c-1.8 0-3-1.2-3-3s1.2-3 3-3 3 1.2 3 3-1.2 3-3 3z" fill="#95BF47"/>
        </svg>
      </div>

      <div class="partner-logo userway">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 32" height="26">
          <circle cx="12" cy="16" r="10" stroke="#fff" stroke-width="2" fill="none"/>
          <path d="M12 10v8M9 13h6M10 21h4" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
          <text x="28" y="22" font-family="system-ui, sans-serif" font-weight="700" font-size="16" fill="#fff" letter-spacing="0.02em">USERWAY</text>
        </svg>
      </div>

      <div class="partner-logo wpengine">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 36" height="32">
          <rect width="140" height="36" rx="4" fill="#fff"/>
          <text x="10" y="15" font-family="system-ui, sans-serif" font-weight="800" font-size="10" fill="#000" letter-spacing="-0.02em">wpengine</text>
          <text x="10" y="28" font-family="system-ui, sans-serif" font-weight="700" font-size="9" fill="#333" letter-spacing="0.02em">AGENCY PARTNER</text>
          <path d="M110 10l12 8-12 8V10z" fill="#40RAFF" />
        </svg>
      </div>
    </div>
  </div>

  <div class="footer-navigation-band">
    <nav class="footer-nav">
      <a href="/team">Team</a>
      <a href="/services">Services</a>
      <a href="/our-work">Our Work</a>
      <a href="/sitemap">Sitemap</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact Us</a>
    </nav>
  </div>
	
  <div class="footer-meta-band">
    <p class="copyright">
      &copy; Copyright {currentYear} CueForGood Solutions Pvt. Ltd. All Rights Reserved. 
      <a href="/privacy-policy" class="privacy-link">Privacy Policy</a>
    </p>
    
    <div class="footer-socials">
      <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.8c4.56-.93 8-4.96 8-9.8z"/></svg>
      </a>
      <a href="https://x.com" target="_blank" rel="noopener noreferrer" aria-label="X (formerly Twitter)">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
